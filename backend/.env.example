# ===== WCCA 后端环境变量示例 =====
# 用法：复制本文件为 .env（同目录），把下面的值换成你的真实配置。
#   cp .env.example .env     （或在资源管理器里复制改名）
# .env 已被 .gitignore 忽略，不会上传，安全存放密钥。

# peng-us 中转的 API 密钥（从 CC Switch 界面里 peng-us 供应商复制）
WCCA_AUTH_TOKEN=sk-在这里填你的peng-us密钥

# 后端地址（一般不用改，默认就是 peng-us 中转）
# WCCA_BASE_URL=https://api.peng-us.com
